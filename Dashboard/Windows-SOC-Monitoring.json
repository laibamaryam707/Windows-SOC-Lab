  "dataSources": {
    "ds_FW49rAx7": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon\n| stats count by EventCode",
        "queryParameters": {}
      },
      "name": "Events by Event ID"
    },
    "ds_hoDXmuAz_ds_FW49rAx7": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon EventCode=1 \n| top User",
        "queryParameters": {}
      },
      "name": "Top Users"
    },
    "ds_slxMrH1H_ds_hoDXmuAz_ds_FW49rAx7": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults count=15 \n| streamstats count \n| eval _time=_time-count*3600\n| eval users=random()%100",
        "queryParameters": {}
      },
      "name": "Active users"
    },
    "ds_kBa7cUgt": {
      "type": "ds.search",
      "options": {
        "query": "|makeresults count=100 |streamstats count | eval _time=_time-count*60 | eval memory=random()%100, cpu=random()%100 \n|  fields _time cpu memory",
        "queryParameters": {}
      },
      "name": "Mem and CPU utilization"
    },
    "ds_zh1XRYil": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon \n| top Computer",
        "queryParameters": {}
      },
      "name": "Active Hosts"
    },
    "ds_lLMVXz2S": {
      "type": "ds.search",
      "options": {
        "query": "| makeresults \n| eval performance=91, availability=98",
        "queryParameters": {}
      },
      "name": "Performance and Availability"
    },
    "ds_ISFxltwR": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon EventCode=1 \n| stats count"
      },
      "name": "Search_1"
    },
    "ds_SPULnep6": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon EventCode=11\n| stats count"
      },
      "name": "Search_2"
    },
    "ds_sLiKbzhn": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon EventCode=1 Image=\"*powershell*\" \n| stats count"
      },
      "name": "Search_3"
    },
    "ds_6uHDB9Fc": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon EventCode=1 Image=\"*cmd.exe\" \n| stats count"
      },
      "name": "Search_4"
    },
    "ds_A4hvZYvD": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon earliest=-5m\n| stats count \n| eval value=if(count>0,100,0)\n| fields value"
      },
      "name": "Search_5"
    },
    "ds_atJ1GaSF": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon \n| stats count \n| eval Health=100"
      },
      "name": "Search_6"
    },
    "ds_UFbva48n": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon EventCode=1 \n| top User"
      },
      "name": "Search_7"
    },
    "ds_RbNqv3XX": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon \n| timechart span=15m count"
      },
      "name": "Search_8"
    },
    "ds_1ocjte7w": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon EventCode=1 \n| top Image limit=10"
      },
      "name": "Search_9"
    },
    "ds_ozpexvgg": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon \n| stats count"
      },
      "name": "Search_10"
    },
    "ds_Csgrej4N": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon \n| table _time EventCode Image User Computer \n| sort -_time \n| head 20"
      },
      "name": "Search_11"
    },
    "ds_CgF8ckGM": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon \n| table _time EventCode Image User Computer \n| sort -_time \n| head 20"
      },
      "name": "Search_12"
    },
    "ds_CH8NmnxH": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon\r\n| eval Technique=case(\r\nEventCode=1,\"Execution\",\r\nEventCode=3,\"Command and Control\",\r\nEventCode=11,\"Collection\",\r\nEventCode=12 OR EventCode=13 OR EventCode=14,\"Persistence\",\r\nEventCode=22,\"Discovery\",\r\ntrue(),\"Other\")\r\n| stats count by Technique"
      },
      "name": "Search_13"
    },
    "ds_Is19V66i": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon\r\n| eval Severity=case(\r\nEventCode IN (1,3),\"High\",\r\nEventCode IN (11,12,13,14),\"Medium\",\r\ntrue(),\"Low\")\r\n| stats count by Severity"
      },
      "name": "Search_14"
    },
    "ds_N2jGTURV": {
      "type": "ds.search",
      "options": {
        "query": "index=sysmon EventCode=1\r\n| search Image=\"*powershell.exe\" OR Image=\"*cmd.exe\" OR Image=\"*rundll32.exe\" OR Image=\"*regsvr32.exe\" OR Image=\"*mshta.exe\" OR Image=\"*wscript.exe\" OR Image=\"*cscript.exe\"\r\n| stats count by Image\r\n| sort -count"
      },
      "name": "Search_15"
    }
  },
  "defaults": {
    "dataSources": {
      "ds.search": {
        "options": {
          "queryParameters": {
            "latest": "$global_time.latest$",
            "earliest": "$global_time.earliest$"
          }
        }
      }
    }
